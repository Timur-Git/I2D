# I2D Backend Environment Configuration

APP_NAME=I2D Backend
DEBUG=False
PORT=8000
HOST=127.0.0.1
API_V1_PREFIX=/api/v1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=i2d_db
DB_USER=postgres
DB_PASSWORD=postgres

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads
MINIO_SECURE=False
MINIO_PUBLIC_ENDPOINT=localhost:9000

SECRET_KEY=change-this-to-very-long-random-string-must-be-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Local run: start ml-sevice on port 8001. Docker Compose overrides this to http://ml:8001/api/v1/generate.
ML_SERVICE_URL=http://localhost:8001/api/v1/generate
ML_SERVICE_TIMEOUT_SECONDS=120

ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ALLOW_METHODS=["*"]
ALLOW_HEADERS=["*"]
